# ============================================================
# AI Work Buddy 环境变量配置
# 复制此文件为 .env 并填入实际值
# 前端和后端共用此文件
# ============================================================

# ── 前端（Vite 构建）─────────────────────────────────────────
# API 基础路径，留空使用同源（Nginx 代理 /api/）
VITE_API_BASE=

# 开发环境代理目标（默认 http://localhost:3000）
VITE_PROXY_TARGET=

# ── 后端（Express 服务器）───────────────────────────────────
# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=buddy
DB_PASSWORD=NX62WP4bDJikBNih
DB_NAME=buddy

# 服务器端口
PORT=3000
